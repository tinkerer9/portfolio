---
interface Props {
	variant?: 'offset' | 'small';
}

const { variant } = Astro.props;
---

<ul class:list={['grid', { offset: variant === 'offset', small: variant === 'small' }]}>
	<slot />
</ul>

<style>
	.grid {
		display: grid;
		grid-auto-rows: 1fr;
		gap: 1rem;
		padding: 0;
		list-style: none;
	}

	.grid.small {
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	/* Make a lone item in the last row span both columns. */
	.grid.small > :global(:last-child:nth-child(odd)) {
		grid-column: 1 / -1;
	}

	@media (min-width: 50em) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 4rem;
		}

		.grid.offset {
			--row-offset: 7.5rem;
			padding-bottom: var(--row-offset);
		}

		/* Stagger the columns. */
		.grid.offset > :global(:nth-child(odd)) {
			grid-column: 2;
		}

		.grid.offset > :global(:nth-child(even)) {
			transform: translateY(var(--row-offset));
			grid-column: 1 / 2;
			grid-row: span 1 / 1;
		}

		.grid.small {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 2rem;
		}

		.grid.small > :global(*) {
			flex: 0 1 20rem;
		}
	}
</style>